# Dockerfile with GUI support via VNC
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    build-essential cmake ninja-build git \
    qt6-base-dev qt6-base-dev-tools \
    xfce4 xfce4-terminal xvfb x11vnc fluxbox \
    novnc websockify \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Setup app
WORKDIR /app
COPY . /app

RUN cmake -S . -B build -G Ninja
RUN cmake --build build

# VNC config
ENV DISPLAY=:99
EXPOSE 6080 5900

CMD ["/bin/bash", "-lc", "Xvfb :99 -screen 0 1280x720x16 & xfce4-session & x11vnc -forever -display :99 -shared -rfbport 5900 & websockify --web=/usr/share/novnc/ 6080 localhost:5900 & tail -f /dev/null"]
